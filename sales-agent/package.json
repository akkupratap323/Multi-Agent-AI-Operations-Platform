{
  "name": "nester-sales-agent",
  "version": "1.0.0",
  "description": "Intelligent cold email sales agent for Nester Voice AI",
  "main": "scripts/run_campaign.js",
  "scripts": {
    "campaign": "node scripts/run_campaign.js",
    "campaign:dry": "node scripts/run_campaign.js --dry-run",
