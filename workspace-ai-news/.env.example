# AI News Agent — Environment Variables
# Copy to .env and fill in values

# Slack bot token (bot that posts AI news summaries)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=C0XXXXXXXXX

# IFTTT Webhook key (for tweet relay integration)
IFTTT_WEBHOOK_KEY=your-ifttt-webhook-key-here

# Port for the IFTTT tweet relay HTTP server
RELAY_PORT=9877
