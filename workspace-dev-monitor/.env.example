# Dev Monitor — Environment Variables
# Copy to .env and fill in values

SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=C0XXXXXXXXX

# Neon PostgreSQL
NEON_DB_URL=postgresql://user:password@host/database?sslmode=require
NEON_API_KEY=napi_your-neon-api-key

# GitHub
GITHUB_TOKEN=ghp_your-github-pat

# Repos to monitor (comma-separated)
GITHUB_REPOS=your-org/your-repo

# Neon project IDs to monitor (comma-separated)
NEON_PROJECTS=your-project-id
