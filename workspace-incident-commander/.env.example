# ============================================================
# Incident Commander — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# Slack Bot Token (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_FALLBACK_CHANNEL=C0XXXXXXXXX

# Database (Neon PostgreSQL connection string)
NEON_DB_URL=postgresql://user:password@host/database?sslmode=require

# LLM — OpenAI (Primary)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# LLM — Gemini (Fallback)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# AWS Region
AWS_REGION=us-west-2

# WhatsApp number to alert
WHATSAPP_TO=+91XXXXXXXXXX

# Gmail OAuth credential file paths
GMAIL_CREDENTIALS=/path/to/gmail-credentials.json
GMAIL_TOKEN=/path/to/google-token.json

# Stakeholder emails (comma-separated)
STAKEHOLDER_EMAILS=you@yourcompany.com

# On-call Slack user ID
ON_CALL_SLACK_USER=UXXXXXXXXX

# GitHub repos to check for recent commits (comma-separated)
GITHUB_REPOS=your-org/your-repo

# Timezone
TIMEZONE=Asia/Kolkata
